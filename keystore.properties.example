# Copy this file to keystore.properties and fill in your release keystore details.
# NEVER commit keystore.properties — add it to .gitignore immediately.
#
# Generate a new release keystore (one-time setup):
#   keytool -genkeypair -v -keystore release.jks \
#     -alias coreguard -keyalg RSA -keysize 4096 -validity 10000
#
# For CI, set the four values as repository / environment secrets instead of
# using this file (see .github/workflows/release.yml for the expected secret names).
storeFile=/path/to/release.jks
storePassword=CHANGEME
keyAlias=coreguard
keyPassword=CHANGEME

<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    style="@style/Widget.CoreGuard.Card"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginBottom="12dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:padding="16dp"
        android:gravity="center_vertical">

        <ImageView
            android:id="@+id/ivCheckRune"
            android:layout_width="26dp"
            android:layout_height="26dp"
            android:importantForAccessibility="no"
            android:src="@drawable/ic_unicursal_hexagram"
            tools:tint="@color/status_pass" />

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:layout_marginStart="14dp"
            android:layout_marginEnd="10dp"
            android:orientation="vertical">

            <TextView
                android:id="@+id/tvCheckName"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:textAppearance="?attr/textAppearanceTitleMedium"
                android:textColor="@color/text_primary"
                tools:text="Root Indicators" />

            <TextView
                android:id="@+id/tvCheckExplanation"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="3dp"
                android:textAppearance="?attr/textAppearanceBodySmall"
                android:textColor="@color/text_secondary"
                tools:text="No common root indicators found." />
        </LinearLayout>

        <TextView
            android:id="@+id/tvCheckState"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:paddingStart="12dp"
            android:paddingEnd="12dp"
            android:paddingTop="5dp"
            android:paddingBottom="5dp"
            android:textAppearance="?attr/textAppearanceLabelMedium"
            android:textStyle="bold"
            android:letterSpacing="0.1"
            tools:text="PASS"
            tools:background="@drawable/bg_state_chip"
            tools:textColor="@color/status_pass" />
    </LinearLayout>
</com.google.android.material.card.MaterialCardView>

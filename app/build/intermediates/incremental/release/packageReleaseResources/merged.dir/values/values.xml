    <style name="TextAppearance.CoreGuard.SectionRune" parent="TextAppearance.Material3.LabelLarge">
        <item name="android:fontFamily">serif</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.24</item>
        <item name="android:textColor">@color/gold</item>
    </style>
    <style name="TextAppearance.CoreGuard.Wordmark" parent="TextAppearance.Material3.HeadlineMedium">
        <item name="android:fontFamily">serif</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textAllCaps">true</item>
        <item name="android:letterSpacing">0.18</item>
        <item name="android:textColor">@color/gold_bright</item>
    </style>
    <style name="Theme.CoreGuard" parent="Theme.Material3.Dark.NoActionBar">
        <item name="colorPrimary">@color/gold</item>
        <item name="colorOnPrimary">@color/obsidian_deep</item>
        <item name="colorPrimaryContainer">@color/gold_deep</item>
        <item name="colorOnPrimaryContainer">@color/gold_bright</item>
        <item name="colorSecondary">@color/ward_teal</item>
        <item name="colorOnSecondary">@color/obsidian_deep</item>
        <item name="android:colorBackground">@color/obsidian</item>
        <item name="colorSurface">@color/surface_dark</item>
        <item name="colorOnSurface">@color/text_primary</item>
        <item name="colorOnSurfaceVariant">@color/text_secondary</item>
        <item name="colorOutline">@color/text_tertiary</item>
        <item name="android:statusBarColor">@color/obsidian_deep</item>
        <item name="android:navigationBarColor">@color/obsidian_deep</item>
        <item name="android:windowBackground">@color/obsidian</item>
    </style>
    <style name="Widget.CoreGuard.Button.Ghost" parent="Widget.Material3.Button.OutlinedButton">
        <item name="strokeColor">@color/gold_deep</item>
        <item name="android:textColor">@color/gold_bright</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="cornerRadius">14dp</item>
    </style>
    <style name="Widget.CoreGuard.Button.Gold" parent="Widget.Material3.Button">
        <item name="backgroundTint">@color/gold</item>
        <item name="android:textColor">@color/obsidian_deep</item>
        <item name="android:textStyle">bold</item>
        <item name="android:letterSpacing">0.06</item>
        <item name="cornerRadius">14dp</item>
    </style>
    <style name="Widget.CoreGuard.Card" parent="Widget.Material3.CardView.Elevated">
        <item name="cardBackgroundColor">@color/surface_card</item>
        <item name="cardCornerRadius">18dp</item>
        <item name="cardElevation">0dp</item>
        <item name="strokeColor">@color/surface_card_stroke</item>
        <item name="strokeWidth">1dp</item>
    </style>
    <declare-styleable name="AegishjalmurView">
        <attr format="color" name="sigilColor"/>
        <attr format="boolean" name="slowRotate"/>
    </declare-styleable>
    <declare-styleable name="GuardianScoreView">
        <attr format="color" name="trackColor"/>
        <attr format="color" name="scoreTextColor"/>
    </declare-styleable>
</resources>